{# 约束定义片段 #}
{# 支持硬约束和软约束分级 #}

{% set hard_constraints = hard_constraints | default([
  "必须使用提供的采访素材中的具体细节：人名、地名、时间、对话、数字",
  "引用采访内容时，在括号中标注来源，如（来源：素材1）",
  "不得编造未在素材中出现的具体人物、事件、地点",
  "必须明确时间点，结合当时的社会背景",
  "每300字必须包含至少1个具体时间、地点、数字或人物对话"
]) %}

{% set soft_constraints = soft_constraints | default([
  "建议使用感官描写增强场景感",
  "建议保持段落长度适中，避免过长段落",
  "建议适当使用对话推动情节"
]) %}

{% set forbidden_items = forbidden_items | default([
  {"type": "占位符", "examples": ["待补充", "待完善", "此处需要展开", "鉴于...尚待补充"]},
  {"type": "模板套话", "examples": ["尘埃在光柱中飞舞", "苦涩中带着回甘", "命运的齿轮"]},
  {"type": "空泛表述", "examples": ["中国社会发展的重要时期", "那是一个特殊的年代"]},
  {"type": "AI声明", "examples": ["我为您撰写", "这是一个通用模板"]},
  {"type": "悬念套路", "examples": ["暴风雨前的宁静", "真相伺机而动", "更大的挑战在等待"]},
  {"type": "情感标签", "examples": ["陷入了沉思", "百感交集", "心中充满", "倍感欣慰"]},
  {"type": "时间套路", "examples": ["时光荏苒", "转眼间", "岁月如梭", "白驹过隙"]},
  {"type": "场景套路", "examples": ["月光如水", "微风轻拂", "阳光正好", "点了一根烟", "望着远方"]}
]) %}

=== 强制要求（违反将导致内容被废弃） ===
{% for constraint in hard_constraints %}
{{ loop.index }}. {{ constraint }}
{% endfor %}

=== 禁止事项（绝对禁止出现） ===
{% for item in forbidden_items %}
{{ loop.index }}. 【{{ item.type }}】{{ item.examples | join('、') }}
{% endfor %}

{% if soft_constraints %}
=== 建议遵守（可记录例外情况） ===
{% for constraint in soft_constraints %}
{{ loop.index }}. {{ constraint }}
{% endfor %}
{% endif %}
