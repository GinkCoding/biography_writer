{# 约束定义片段 #}
{# 支持硬约束和软约束分级 #}

{% set hard_constraints = hard_constraints | default([
  "人名、关系、时间、地点、先后顺序等硬事实，不能与素材和前文冲突",
  "不得凭空编造会改变人物命运或关系走向的重大事件",
  "优先吸收素材中的具体细节，但不要把内部来源标记直接写进正文",
  "素材不足时，可用克制、保守的写法保持模糊，不能硬造精确细节",
  "正文中不得出现占位符、提纲语句、编辑批注、模型自述"
]) %}

{% set soft_constraints = soft_constraints | default([
  "尽量让细节自然落在叙事里，不要像清单一样堆砌",
  "优先用动作、对话、场景承载情绪，而不是直接贴情绪标签",
  "段落节奏有一点变化，避免整节都一个腔调",
  "有文学性，但不要为了漂亮而牺牲清楚和可信"
]) %}

{% set forbidden_items = forbidden_items | default([
  {"type": "占位符或批注", "examples": ["待补充", "待完善", "此处需要展开", "主旨运用", "本段功能", "写作提示"]},
  {"type": "明显套话", "examples": ["命运的齿轮", "暴风雨前的宁静", "真相伺机而动"]},
  {"type": "空泛大话", "examples": ["中国社会发展的重要时期", "那是一个特殊的年代", "波澜壮阔的岁月"]},
  {"type": "AI暴露语句", "examples": ["我为您撰写", "以下是根据素材生成", "这是一段通用模板"]},
  {"type": "空心情绪标签", "examples": ["陷入了沉思", "百感交集", "心中充满复杂情绪"]},
  {"type": "硬造悬念", "examples": ["更大的挑战还在后面", "谁也没想到，这只是开始"]},
]) %}

=== 底线要求 ===
{% for constraint in hard_constraints %}
{{ loop.index }}. {{ constraint }}
{% endfor %}

=== 明显要避开的写法 ===
{% for item in forbidden_items %}
{{ loop.index }}. 【{{ item.type }}】{{ item.examples | join('、') }}
{% endfor %}

{% if soft_constraints %}
=== 写法建议 ===
{% for constraint in soft_constraints %}
{{ loop.index }}. {{ constraint }}
{% endfor %}
{% endif %}
