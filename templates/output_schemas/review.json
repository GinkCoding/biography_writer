{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReviewResult",
  "description": "审校结果的输出格式",
  "type": "object",
  "required": ["overall_passed", "overall_score", "dimensions"],
  "properties": {
    "overall_passed": {
      "type": "boolean",
      "description": "是否通过整体审校"
    },
    "overall_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "整体得分"
    },
    "dimensions": {
      "type": "object",
      "description": "各维度审校结果",
      "properties": {
        "continuity": {
          "type": "object",
          "properties": {
            "passed": {"type": "boolean"},
            "score": {"type": "integer", "minimum": 0, "maximum": 100}
          }
        },
        "fact_accuracy": {
          "type": "object",
          "properties": {
            "passed": {"type": "boolean"},
            "score": {"type": "integer", "minimum": 0, "maximum": 100}
          }
        },
        "quality": {
          "type": "object",
          "properties": {
            "passed": {"type": "boolean"},
            "score": {"type": "integer", "minimum": 0, "maximum": 100}
          }
        },
        "cleanliness": {
          "type": "object",
          "properties": {
            "passed": {"type": "boolean"},
            "score": {"type": "integer", "minimum": 0, "maximum": 100}
          }
        }
      }
    },
    "issues": {
      "type": "array",
      "description": "发现的问题列表",
      "items": {
        "type": "object",
        "required": ["type", "description", "severity"],
        "properties": {
          "dimension": {
            "type": "string",
            "enum": ["continuity", "fact", "quality", "cleanliness"]
          },
          "type": {"type": "string"},
          "location": {"type": "string"},
          "description": {"type": "string"},
          "severity": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "suggestion": {"type": "string"}
        }
      }
    },
    "summary": {
      "type": "string",
      "description": "审校总结"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "review_time": {"type": "string", "format": "date-time"},
        "reviewer": {"type": "string"},
        "chapter_id": {"type": "string"}
      }
    }
  }
}
