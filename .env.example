# 大模型API配置（用于生成传记内容）
# 支持的provider: openai, claude, moonshot, deepseek, zhipu, kimi

# OpenAI
API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1

# 或 国产模型（智谱）
# API_KEY=your_zhipu_api_key
# MODEL_PROVIDER=zhipu
# MODEL=glm-4

# 或 使用Kimi（推荐国内用户）
# MODEL_PROVIDER=kimi

# ============================================
# Embedding模型配置（用于语义检索）
# ============================================

# 推荐：硅基流动 SiliconFlow（国内访问稳定，中文效果优秀）
# 注册获取API密钥: https://siliconflow.cn
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# 可选：OpenAI Embedding（需要国外网络或代理）
# OPENAI_API_KEY=your_openai_api_key_here

# 说明:
# 1. 硅基流动支持 BAAI/bge-large-zh-v1.5 等中文Embedding模型
# 2. 新用户注册硅基流动可获得免费Token额度
# 3. 如果都不配置，会自动回退到本地SentenceTransformer模型（首次使用需下载约200MB模型文件）
